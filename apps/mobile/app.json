{
  "expo": {
    "name": "Korneo",
    "slug": "korneo-mobile",
    "version": "1.0.0",
    "scheme": "korneo",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f172a",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-router"
    ],
    "android": {
      "package": "com.tkolya.korneo",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.tkolya.korneo",
      "supportsTablet": true
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
